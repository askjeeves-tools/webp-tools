{
	"name": "webp-tools",
	"version": "0.1.9",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "astro dev",
		"generate:llms-txt": "vite-node scripts/generate-llms-txt.ts",
		"prebuild": "pnpm run generate:seo-images && pnpm run generate:llms-txt",
		"build": "astro build",
		"preview": "astro preview",
		"deploy": "pnpm run build && wrangler pages deploy dist",
		"pretest:e2e": "pnpm run build",
		"test:e2e": "playwright test",
		"generate:seo-images": "node scripts/generate-seo-images.mjs",
		"lint": "biome check .",
		"preinstall": "npx only-allow pnpm"
	},
	"dependencies": {
		"@askjeeves/astro-integration": "file:./vendor/@askjeeves/astro-integration",
		"@askjeeves/conversion-core": "file:./vendor/@askjeeves/conversion-core",
		"@askjeeves/processors-images": "file:./vendor/@askjeeves/processors-images",
		"@askjeeves/ui": "file:./vendor/@askjeeves/ui",
		"@astrojs/sitemap": "^3.7.0",
		"astro": "6.4.6"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"sharp": "^0.34.3",
		"typescript": "^5.9.2",
		"vite-node": "^3.2.4",
		"wrangler": "^4.100.0"
	},
	"packageManager": "pnpm@10.27.0",
	"pnpm": {
		"onlyBuiltDependencies": [
			"sharp"
		]
	}
}
